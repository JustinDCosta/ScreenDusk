<Window x:Class="ScreenDusk.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenDusk"
        Width="500"
        Height="620"
        MinWidth="460"
        MinHeight="580"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        FontFamily="Segoe UI Variable Text"
        AllowsTransparency="True"
        WindowStyle="None">
    <Window.Resources>
        <LinearGradientBrush x:Key="ShellBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFF6F9FC" Offset="0" />
            <GradientStop Color="#FFEAF0F7" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="Foreground" Value="#FF1F2937" />
            <Setter Property="BorderBrush" Value="#220B1F36" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="DemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#18FFFFFF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#2A0B1F36" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#24000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Background" Value="#FF0067C0" />
            <Setter Property="BorderBrush" Value="#00000000" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="#FCFFFFFF" />
            <Setter Property="BorderBrush" Value="#25000000" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#FF111827" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,10,0,0" />
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="{StaticResource BrushAccent}" />
        </Style>
    </Window.Resources>
    <Grid Background="{StaticResource ShellBackgroundBrush}">
        <Border CornerRadius="20"
                BorderBrush="#24000000"
                BorderThickness="1"
                Background="#F9FFFFFF"
                Margin="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.14" />
            </Border.Effect>

            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10" Background="Transparent" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ScreenDusk" FontSize="24" FontWeight="SemiBold" Foreground="#FF0F172A" />
                        <TextBlock Text="Comfort dimming overlay for late-night use" FontSize="12" Foreground="#FF5B6678" Margin="0,2,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Button Style="{StaticResource TitleBarButtonStyle}" Content="_" Click="MinimizeButton_OnClick" />
                        <Button x:Name="MaximizeRestoreButton" Margin="6,0,0,0" Style="{StaticResource TitleBarButtonStyle}" Content="[]" Click="MaximizeRestoreButton_OnClick" />
                        <Button Margin="6,0,0,0" Style="{StaticResource TitleBarButtonStyle}" Content="X" Click="CloseButton_OnClick" />
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="1"
                           Margin="0,4,0,18"
                           Text="Go darker than your monitor's default brightness with a software dimming overlay."
                           Foreground="#FF455266"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Row="2">
                    <Border CornerRadius="14" Padding="18" BorderBrush="#1A000000" BorderThickness="1" Background="#5CFFFFFF">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Dimming level" FontSize="14" FontWeight="SemiBold" Foreground="#FF111827" VerticalAlignment="Center" />
                                <TextBlock DockPanel.Dock="Right" Text="{Binding DimLevelText}" FontSize="15" FontWeight="SemiBold" Foreground="#FF0B63B6" />
                            </DockPanel>
                            <Slider Minimum="0"
                                    Maximum="100"
                                    Value="{Binding DimLevelPercent, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="False"
                                    Margin="0,16,0,0"
                                    LargeChange="5"
                                    SmallChange="1" />
                        </StackPanel>
                    </Border>

                    <CheckBox Margin="0,14,0,0"
                              IsChecked="{Binding IsDimmingEnabled}"
                              Content="Enable dimming" />

                    <CheckBox IsChecked="{Binding LaunchOnStartup}"
                              Content="Launch on Windows startup" />

                    <CheckBox IsChecked="{Binding MinimizeToTray}"
                              Content="Minimize to system tray" />

                    <Border CornerRadius="12" Padding="14" BorderBrush="#1A000000" BorderThickness="1" Background="#4FFFFFFF" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Custom Hotkeys" FontSize="14" FontWeight="SemiBold" Foreground="#FF111827" />
                            <TextBlock Text="Modifier keys stay fixed as Ctrl + Alt." Margin="0,4,0,10" FontSize="12" Foreground="#FF5B6678" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Increase dimming" VerticalAlignment="Center" Margin="0,0,12,8" />
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding AvailableHotkeyKeys}"
                                          SelectedItem="{Binding IncreaseHotkeyKey, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,0,0,8" />

                                <TextBlock Grid.Row="1" Text="Decrease dimming" VerticalAlignment="Center" Margin="0,0,12,8" />
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          ItemsSource="{Binding AvailableHotkeyKeys}"
                                          SelectedItem="{Binding DecreaseHotkeyKey, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,0,0,8" />

                                <TextBlock Grid.Row="2" Text="Toggle dimming" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <ComboBox Grid.Row="2" Grid.Column="1"
                                          ItemsSource="{Binding AvailableHotkeyKeys}"
                                          SelectedItem="{Binding ToggleHotkeyKey, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Margin="0,16,0,0"
                               Text="Hotkeys apply immediately when you change them."
                               Foreground="#FF5B6678"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="3" Margin="0,22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Content="Hide to Tray"
                            Command="{Binding HideToTrayCommand}"
                            Style="{StaticResource GhostButtonStyle}"
                            MinWidth="118"
                            Grid.Column="1" />

                    <Button Content="Quit"
                            Command="{Binding ExitCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            MinWidth="90"
                            Grid.Column="3" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
