<Window x:Class="ScreenDusk.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenDusk"
        Width="430"
        Height="390"
        MinWidth="360"
        MinHeight="340"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        MouseLeftButtonDown="Window_OnMouseLeftButtonDown">
    <Window.Resources>
        <LinearGradientBrush x:Key="BackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource AppBackgroundStart}" Offset="0" />
            <GradientStop Color="{StaticResource AppBackgroundEnd}" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="6"
                                    VerticalAlignment="Center"
                                    CornerRadius="3"
                                    Background="#18000000" />
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Background="{StaticResource BrushAccent}"
                                                  BorderThickness="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16" Background="White" BorderBrush="#22000000" BorderThickness="1" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Background="Transparent"
                                                  BorderThickness="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Border CornerRadius="20"
                BorderBrush="{StaticResource BrushPanelBorder}"
                BorderThickness="1"
                Background="{StaticResource BrushPanelBackground}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.22" />
            </Border.Effect>

            <Grid Margin="22" Background="{StaticResource BackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,2">
                    <TextBlock Text="Screen Dimmer"
                               FontSize="24"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Width="34"
                            Height="34"
                            Margin="10,0,0,0"
                            Content="X"
                            Click="CloseButton_OnClick"
                            BorderThickness="0"
                            DockPanel.Dock="Right"
                            Background="#11000000" />
                </DockPanel>

                <TextBlock Grid.Row="1"
                           Margin="0,8,0,20"
                           Text="Go darker than your monitor's default brightness with a software dimming overlay."
                           Foreground="{StaticResource BrushSubtleText}"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Row="2">
                    <Border CornerRadius="14" Padding="16" BorderBrush="{StaticResource BrushPanelBorder}" BorderThickness="1">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Dimming level" FontSize="14" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding DimLevelText}" FontSize="14" DockPanel.Dock="Right" />
                            </DockPanel>
                            <Slider Minimum="0"
                                    Maximum="100"
                                    Value="{Binding DimLevelPercent, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="False"
                                    Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <CheckBox Margin="0,16,0,0"
                              IsChecked="{Binding IsDimmingEnabled}"
                              Content="Enable dimming" />

                    <CheckBox Margin="0,8,0,0"
                              IsChecked="{Binding LaunchOnStartup}"
                              Content="Launch on Windows startup" />

                    <CheckBox Margin="0,8,0,0"
                              IsChecked="{Binding MinimizeToTray}"
                              Content="Minimize to system tray" />

                    <TextBlock Margin="0,14,0,0"
                               Text="Hotkeys: Ctrl + Alt + Up/Down (brightness), Ctrl + Alt + D (toggle)"
                               Foreground="{StaticResource BrushSubtleText}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <DockPanel Grid.Row="3" Margin="0,18,0,0" LastChildFill="False">
                    <Button Content="Hide to Tray"
                            Width="110"
                            Height="34"
                            Padding="10,0"
                            Click="HideToTrayButton_OnClick"
                            BorderThickness="0"
                            Background="#11000000" />
                    <Button Content="Quit"
                            Width="92"
                            Height="34"
                            Margin="8,0,0,0"
                            Padding="10,0"
                            Click="CloseButton_OnClick"
                            BorderThickness="0"
                            Background="{StaticResource BrushAccent}"
                            Foreground="White"
                            DockPanel.Dock="Right" />
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
