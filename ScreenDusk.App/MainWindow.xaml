<Window x:Class="ScreenDusk.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenDusk"
        Width="460"
        Height="500"
        MinWidth="400"
        MinHeight="460"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        FontFamily="Segoe UI Variable Text"
        AllowsTransparency="True"
        WindowStyle="None">
    <Window.Resources>
        <LinearGradientBrush x:Key="ShellBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF8FAFD" Offset="0" />
            <GradientStop Color="#FFE7EDF6" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#10FFFFFF" />
            <Setter Property="Foreground" Value="#FF1F2937" />
            <Setter Property="BorderBrush" Value="#220B1F36" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#18FFFFFF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#2A0B1F36" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#24000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Background" Value="#FF0067C0" />
            <Setter Property="BorderBrush" Value="#00000000" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="TitleCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontFamily" Value="Segoe UI Symbol" />
            <Setter Property="Content" Value="&#xE711;" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#FF111827" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,10,0,0" />
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="{StaticResource BrushAccent}" />
        </Style>
    </Window.Resources>
    <Grid Background="{StaticResource ShellBackgroundBrush}">
        <Ellipse Width="280" Height="280" Fill="#18FFFFFF" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-80,-90,0,0" IsHitTestVisible="False" />
        <Ellipse Width="200" Height="200" Fill="#10FFFFFF" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-60,-50" IsHitTestVisible="False" />

        <Border CornerRadius="20"
                BorderBrush="#24000000"
                BorderThickness="1"
                Background="#F9FFFFFF"
                Margin="18">
            <Border.Effect>
                <DropShadowEffect BlurRadius="26" ShadowDepth="8" Opacity="0.16" />
            </Border.Effect>

            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="36" Height="36" CornerRadius="10" Background="#150067C0" VerticalAlignment="Center">
                        <TextBlock Text="SD" FontWeight="Bold" Foreground="{StaticResource BrushAccent}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Screen Dimmer" FontSize="24" FontWeight="SemiBold" Foreground="#FF0F172A" />
                        <TextBlock Text="Comfort dimming overlay for late-night focus" FontSize="12" Foreground="#FF5B6678" Margin="0,2,0,0" />
                    </StackPanel>

                    <Button Grid.Column="2" Style="{StaticResource TitleCloseButtonStyle}" Command="{Binding ExitCommand}" />
                </Grid>

                <TextBlock Grid.Row="1"
                           Margin="0,4,0,18"
                           Text="Go darker than your monitor's default brightness with a software dimming overlay."
                           Foreground="#FF455266"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Row="2">
                    <Border CornerRadius="14" Padding="18" BorderBrush="#1A000000" BorderThickness="1" Background="#5CFFFFFF">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Dimming level" FontSize="14" FontWeight="SemiBold" Foreground="#FF111827" VerticalAlignment="Center" />
                                <Border DockPanel.Dock="Right" CornerRadius="8" Padding="9,3" Background="#140078D4">
                                    <TextBlock Text="{Binding DimLevelText}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource BrushAccent}" />
                                </Border>
                            </DockPanel>
                            <Slider Minimum="0"
                                    Maximum="100"
                                    Value="{Binding DimLevelPercent, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="False"
                                    Margin="0,16,0,0"
                                    LargeChange="5"
                                    SmallChange="1" />
                        </StackPanel>
                    </Border>

                    <CheckBox Margin="0,14,0,0"
                              IsChecked="{Binding IsDimmingEnabled}"
                              Content="Enable dimming" />

                    <CheckBox IsChecked="{Binding LaunchOnStartup}"
                              Content="Launch on Windows startup" />

                    <CheckBox IsChecked="{Binding MinimizeToTray}"
                              Content="Minimize to system tray" />

                    <TextBlock Margin="0,16,0,0"
                               Text="Hotkeys: Ctrl + Alt + Up/Down (brightness), Ctrl + Alt + D (toggle)"
                               Foreground="#FF5B6678"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="3" Margin="0,22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Content="Hide to Tray"
                            Command="{Binding HideToTrayCommand}"
                            Style="{StaticResource GhostButtonStyle}"
                            MinWidth="118"
                            Grid.Column="1" />

                    <Button Content="Quit"
                            Command="{Binding ExitCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            MinWidth="90"
                            Grid.Column="3" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
