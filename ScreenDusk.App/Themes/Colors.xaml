<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackgroundStart">#FFF5F7FA</Color>
    <Color x:Key="AppBackgroundEnd">#FFE7ECF4</Color>
    <Color x:Key="PanelBackground">#F9FFFFFF</Color>
    <Color x:Key="PanelBorder">#22000000</Color>
    <Color x:Key="AccentColor">#FF0078D4</Color>
    <Color x:Key="SubtleText">#FF5E6673</Color>

    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="BrushPanelBackground" Color="{StaticResource PanelBackground}" />
    <SolidColorBrush x:Key="BrushPanelBorder" Color="{StaticResource PanelBorder}" />
    <SolidColorBrush x:Key="BrushSubtleText" Color="{StaticResource SubtleText}" />
</ResourceDictionary>
